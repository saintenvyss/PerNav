{
  "manifest_version": 3,
  "name": "PerNav",
  "version": "0.2.0",
  "description": "Open-source AI sidebar that drives your browser, powered by your own Claude subscription or API key via a local bridge.",
  "permissions": ["debugger", "sidePanel", "tabs", "activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "background": { "service_worker": "background.js" },
  "side_panel": { "default_path": "sidepanel.html" },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "PerNav",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  }
}
